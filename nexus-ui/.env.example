# OIDC Configuration - set to your Cognito User Pool or OIDC provider
VITE_OIDC_AUTHORITY=https://cognito-idp.<region>.amazonaws.com/<user-pool-id>
VITE_OIDC_CLIENT_ID=<your-client-id>

# API Gateway endpoint (from ccwb deploy nexus output)
VITE_API_URL=https://<api-id>.execute-api.<region>.amazonaws.com
