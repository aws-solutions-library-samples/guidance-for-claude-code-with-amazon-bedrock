<?xml version="1.0" encoding="utf-8"?>
<!--
  ABOUTME: English language strings for ClaudeCowork3P.admx
  ABOUTME: Display names and descriptions shown in Group Policy Editor / Intune
-->
<policyDefinitionResources xmlns:xsd="http://www.w3.org/2001/XMLSchema"
                           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                           xmlns="http://schemas.microsoft.com/GroupPolicy/2006/07/PolicyDefinitions"
                           revision="1.0" schemaVersion="1.0">
  <displayName>Claude Cowork 3P (Amazon Bedrock)</displayName>
  <description>Managed settings for Claude Desktop with Amazon Bedrock as the third-party inference provider.</description>
  <resources>
    <stringTable>
      <string id="Cat_ClaudeCowork">Claude Cowork 3P (Bedrock)</string>
      <string id="Cat_Inference">Inference</string>
      <string id="Cat_Features">Features</string>
      <string id="Cat_Monitoring">Monitoring</string>

      <string id="InferenceProvider">Inference Provider</string>
      <string id="InferenceProvider_Explain">Set the inference provider to "bedrock" for Amazon Bedrock. When enabled, Claude Desktop routes all model requests through your AWS account. Disable to allow users to choose their own provider.</string>

      <string id="InferenceBedrockRegion">Bedrock Region</string>
      <string id="InferenceBedrockRegion_Explain">The AWS region where Amazon Bedrock model endpoints are available (e.g., us-east-1, us-west-2, eu-west-1). This determines which regional Bedrock endpoint Claude Desktop uses for inference. Must match a region where your organization has Bedrock model access enabled.</string>

      <string id="InferenceBedrockProfile">AWS Profile Name</string>
      <string id="InferenceBedrockProfile_Explain">The AWS CLI named profile that Claude Desktop uses for authentication. This profile must exist in the user's ~/.aws/config and should have credential_process configured to point at the CCWB credential helper binary.

Default: "ClaudeCode" (matches the profile name generated by ccwb package).</string>

      <string id="InferenceModels">Model Aliases</string>
      <string id="InferenceModels_Explain">JSON array of model aliases available to users (e.g., ["opus","sonnet","haiku"]). Claude Desktop maps these aliases to the corresponding Bedrock model IDs internally.

Default: ["opus","sonnet","haiku"]</string>

      <string id="ClaudeCodeForDesktop">Enable Claude Code for Desktop</string>
      <string id="ClaudeCodeForDesktop_Explain">Allow users to launch Claude Code (terminal agent) from within Claude Desktop. When disabled, the "Open in Code" option is hidden.</string>

      <string id="DesktopExtension">Enable Desktop Extensions</string>
      <string id="DesktopExtension_Explain">Allow Claude Desktop to load MCP server extensions (both from the extension directory and user-configured servers). Disabling this removes all extension functionality.</string>

      <string id="LocalDevMcp">Enable Local Dev MCP Servers</string>
      <string id="LocalDevMcp_Explain">Allow users to configure local development MCP servers (connecting to localhost endpoints). When disabled, only organization-managed MCP servers can be used.</string>

      <string id="OtlpEndpoint">OTLP Telemetry Endpoint</string>
      <string id="OtlpEndpoint_Explain">HTTP endpoint for OpenTelemetry metrics collection. Claude Desktop sends usage metrics (tokens, latency, model selection) to this endpoint using OTLP/HTTP protocol.

For sidecar mode: http://localhost:4318
For central collector: Your ALB/CloudFront OTLP endpoint URL

Leave empty to disable telemetry collection.</string>

      <string id="OtlpHeaders">OTLP Headers (JSON)</string>
      <string id="OtlpHeaders_Explain">JSON object of HTTP headers to include with OTLP requests. Used for authentication tokens (e.g., {"X-Cowork-Token": "your-token"}) when the collector requires auth.

Leave empty if no authentication headers are needed (e.g., sidecar mode with SigV4).</string>
    </stringTable>
    <presentationTable>
      <presentation id="InferenceBedrockRegion">
        <textBox refId="BedrockRegion">
          <label>AWS Region:</label>
          <defaultValue>us-east-1</defaultValue>
        </textBox>
      </presentation>
      <presentation id="InferenceBedrockProfile">
        <textBox refId="BedrockProfile">
          <label>Profile name:</label>
          <defaultValue>ClaudeCode</defaultValue>
        </textBox>
      </presentation>
      <presentation id="InferenceModels">
        <textBox refId="Models">
          <label>Model aliases (JSON array):</label>
          <defaultValue>["opus","sonnet","haiku"]</defaultValue>
        </textBox>
      </presentation>
      <presentation id="OtlpEndpoint">
        <textBox refId="Endpoint">
          <label>OTLP HTTP endpoint URL:</label>
        </textBox>
      </presentation>
      <presentation id="OtlpHeaders">
        <textBox refId="Headers">
          <label>Headers JSON:</label>
        </textBox>
      </presentation>
    </presentationTable>
  </resources>
</policyDefinitionResources>
